server {
    listen 80;
    listen [::]:80;
    server_name {{ domain }}{% for a in aliases %} {{ a }}{% endfor %};

    # `alias` (not `root`) so nginx serves
    # <acme_challenge_root>/<token>, not
    # <acme_challenge_root>/.well-known/acme-challenge/<token>.
    # The trailing slash on both location and alias is required.
    location /.well-known/acme-challenge/ {
        alias {{ acme_challenge_root }}/;
        try_files $uri =404;
        default_type "text/plain";
        autoindex off;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name {{ domain }}{% for a in aliases %} {{ a }}{% endfor %};
    root {{ root_dir }};
    index index.php index.html index.htm;

    ssl_certificate     {{ cert_path }};
    ssl_certificate_key {{ key_path }};
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384;
    ssl_prefer_server_ciphers on;
    ssl_session_cache shared:SSL:10m;

    add_header Strict-Transport-Security "max-age=63072000; includeSubDomains" always;
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    server_tokens off;

    access_log {{ logs_dir }}/access.log;
    error_log  {{ logs_dir }}/error.log;

    {%- if has_php %}
    location ~ \.php$ {
        try_files $uri =404;
        fastcgi_split_path_info ^(.+\.php)(/.+)$;
        fastcgi_pass unix:/run/php/{{ php_version }}/{{ system_user }}.sock;
        fastcgi_index index.php;
        include fastcgi_params;
        fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
        fastcgi_read_timeout 60s;
    }
    {%- endif %}

    location ~ /\.(?!well-known) {
        deny all;
    }

    location / {
        {%- if has_php %}
        try_files $uri $uri/ /index.php?$args;
        {%- else %}
        try_files $uri $uri/ =404;
        {%- endif %}
    }
}
