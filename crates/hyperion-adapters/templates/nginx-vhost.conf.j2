{%- if maintenance_mode %}
# Maintenance mode toggled ON via /hostings/<domain> detail page.
# Every request returns 503 with a generic page. ACME challenges
# still served so LE renewals don't break.
server {
    listen 80;
    listen [::]:80;
    server_name {{ domain }}{% for a in aliases %} {{ a }}{% endfor %};
    location /.well-known/acme-challenge/ {
        alias {{ acme_challenge_root }}/;
        try_files $uri =404;
        default_type "text/plain";
        autoindex off;
    }
    location / { return 503; }
}
server {
    # `http2` as listen parameter — see nginx-panel.conf.j2 for the
    # rationale. Standalone `http2 on;` only works on nginx ≥ 1.25.1;
    # Debian 12 ships 1.22 and would emit
    # `unknown directive "http2"` on every reload.
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name {{ domain }}{% for a in aliases %} {{ a }}{% endfor %};
    ssl_certificate     {{ cert_path }};
    ssl_certificate_key {{ key_path }};
    ssl_protocols TLSv1.2 TLSv1.3;
    error_page 503 @maintenance;
    location @maintenance {
        root /var/lib/hyperion/maintenance;
        try_files /maintenance.html =503;
        internal;
        add_header Cache-Control "no-store" always;
        add_header Retry-After "300" always;
    }
    location / { return 503; }
}
{%- else %}
server {
    listen 80;
    listen [::]:80;
    server_name {{ domain }}{% for a in aliases %} {{ a }}{% endfor %};

    # `alias` (not `root`) so nginx serves
    # <acme_challenge_root>/<token>, not
    # <acme_challenge_root>/.well-known/acme-challenge/<token>.
    # The trailing slash on both location and alias is required.
    location /.well-known/acme-challenge/ {
        alias {{ acme_challenge_root }}/;
        try_files $uri =404;
        default_type "text/plain";
        autoindex off;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

{%- if fastcgi_cache_enabled %}
# Per-hosting FastCGI cache (operator-enabled, TTL {{ fastcgi_cache_ttl }}s).
# zone name + path namespaced by hosting_id so multiple hostings on
# the same node don't collide and a Purge button can clear ONE cache
# at a time. The fastcgi_cache_path declaration MUST live at http{}
# level — the agent writes it to /etc/nginx/conf.d/hyperion-cache-{{ hosting_id }}.conf
# parallel to writing the vhost, and the include directive there
# picks it up.
{%- endif %}

server {
    # `http2` as listen parameter — Debian 12 nginx 1.22 doesn't
    # understand standalone `http2 on;`. See top of file for context.
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name {{ domain }}{% for a in aliases %} {{ a }}{% endfor %};
    root {{ root_dir }};
    index index.php index.html index.htm;

    ssl_certificate     {{ cert_path }};
    ssl_certificate_key {{ key_path }};
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384;
    ssl_prefer_server_ciphers on;
    ssl_session_cache shared:SSL:10m;

    {%- if hsts_max_age > 0 %}
    add_header Strict-Transport-Security "max-age={{ hsts_max_age }}; includeSubDomains" always;
    {%- endif %}
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    server_tokens off;

    {%- if waf_enabled %}
    # ─── WAF-lite (operator-enabled, Settings → Security) ───
    # `if` + `return` is one of the two officially-safe uses of `if`
    # inside a server block. Conservative patterns only — no attempt to
    # be a full ModSecurity ruleset, which would false-positive on
    # legitimate WP traffic.
    # 1. 403 obvious probe query-strings (path traversal, SQLi, RFI).
    if ($args ~* "(\.\./|\.\.%2f|union(\s|\+|%20)+select|base64_(en|de)code\s*\(|/etc/passwd|\beval\s*\(|<script)") {
        return 403;
    }
    # 2. 403 known scanner / vulnerability-probe user-agents.
    if ($http_user_agent ~* "(nikto|sqlmap|nmap|masscan|jorgee|zgrab|wpscan|libredtail|fuzz)") {
        return 403;
    }
    {%- endif %}

    access_log {{ logs_dir }}/access.log;
    error_log  {{ logs_dir }}/error.log;

    {%- if basic_auth_enabled %}
    # Site-wide HTTP basic auth — agent writes the .htpasswd file
    # alongside this vhost. ACME challenges below are excluded so
    # LE renewals don't get 401'd.
    auth_basic           "Restricted";
    auth_basic_user_file /etc/nginx/.htpasswd-{{ hosting_id }};
    {%- endif %}

    # Always allow ACME challenges past basic-auth.
    location /.well-known/acme-challenge/ {
        {%- if basic_auth_enabled %}
        auth_basic off;
        {%- endif %}
        alias {{ acme_challenge_root }}/;
        try_files $uri =404;
        default_type "text/plain";
        autoindex off;
    }

    {%- if waf_enabled %}
    # WAF-lite: deny direct access to sensitive files + dumps. These
    # are regex locations, so they're declared before `location ~ \.php$`
    # to win the first-match.
    location = /xmlrpc.php { deny all; }
    location = /wp-config.php { deny all; }
    location = /readme.html { deny all; }
    location = /license.txt { deny all; }
    location ~* \.(sql|bak|old|orig|save|swp|tar|gz|tgz|zip|log|ini|sh)$ { deny all; }
    {%- if has_php %}
    # WAF-lite: block PHP execution under upload + cache dirs (the most
    # common WordPress malware-drop vector).
    location ~* /wp-content/(uploads|cache)/.*\.php$ { deny all; }
    {%- endif %}
    {%- endif %}

    {%- if !wp_admin_allow.is_empty() %}
    # ─── wp-admin IP allowlist (operator-enabled, Settings → Security) ───
    # admin-ajax.php stays public: themes/plugins use it for
    # unauthenticated front-end AJAX (carts, search, contact forms).
    location = /wp-admin/admin-ajax.php {
        {%- if has_php %}
        try_files $uri =404;
        fastcgi_split_path_info ^(.+\.php)(/.+)$;
        fastcgi_pass unix:/run/php/{{ php_version }}/{{ system_user }}.sock;
        fastcgi_index index.php;
        include fastcgi_params;
        fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
        fastcgi_read_timeout 60s;
        {%- endif %}
    }
    location = /wp-login.php {
        {%- for cidr in wp_admin_allow %}
        allow {{ cidr }};
        {%- endfor %}
        deny all;
        {%- if has_php %}
        try_files $uri =404;
        fastcgi_split_path_info ^(.+\.php)(/.+)$;
        fastcgi_pass unix:/run/php/{{ php_version }}/{{ system_user }}.sock;
        fastcgi_index index.php;
        include fastcgi_params;
        fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
        fastcgi_read_timeout 60s;
        {%- endif %}
    }
    location ^~ /wp-admin/ {
        {%- for cidr in wp_admin_allow %}
        allow {{ cidr }};
        {%- endfor %}
        deny all;
        {%- if has_php %}
        location ~ \.php$ {
            {%- for cidr in wp_admin_allow %}
            allow {{ cidr }};
            {%- endfor %}
            deny all;
            try_files $uri =404;
            fastcgi_split_path_info ^(.+\.php)(/.+)$;
            fastcgi_pass unix:/run/php/{{ php_version }}/{{ system_user }}.sock;
            fastcgi_index index.php;
            include fastcgi_params;
            fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
            fastcgi_read_timeout 60s;
        }
        {%- endif %}
    }
    # ─── end wp-admin allowlist ───
    {%- endif %}

    {%- if has_php %}
    location ~ \.php$ {
        try_files $uri =404;
        fastcgi_split_path_info ^(.+\.php)(/.+)$;
        fastcgi_pass unix:/run/php/{{ php_version }}/{{ system_user }}.sock;
        fastcgi_index index.php;
        include fastcgi_params;
        fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
        fastcgi_read_timeout 60s;
        {%- if fastcgi_cache_enabled %}
        fastcgi_cache hyperion_{{ hosting_id }};
        fastcgi_cache_valid 200 301 302 {{ fastcgi_cache_ttl }}s;
        fastcgi_cache_methods GET HEAD;
        fastcgi_cache_bypass $cookie_wordpress_logged_in $cookie_PHPSESSID;
        fastcgi_no_cache $cookie_wordpress_logged_in $cookie_PHPSESSID;
        fastcgi_cache_key "$scheme$request_method$host$request_uri";
        add_header X-Cache-Status $upstream_cache_status;
        {%- endif %}
    }
    {%- endif %}

    location ~ /\.(?!well-known) {
        deny all;
    }

    location / {
        {%- if has_php %}
        try_files $uri $uri/ /index.php?$args;
        {%- else %}
        try_files $uri $uri/ =404;
        {%- endif %}
    }

    {%- if !custom_nginx_snippet.is_empty() %}

    # ─── Custom snippet from operator (Settings → Custom config) ───
    {{ custom_nginx_snippet }}
    # ─── end custom snippet ───
    {%- endif %}
}
{%- endif %}
