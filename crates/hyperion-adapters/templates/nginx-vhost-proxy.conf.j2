server {
    listen 80;
    listen [::]:80;
    server_name {{ domain }}{% for a in aliases %} {{ a }}{% endfor %};

    # ACME — same alias trick as the PHP vhost so HTTP-01 challenges
    # work without nginx looking under .well-known/ as a sub-prefix.
    location /.well-known/acme-challenge/ {
        alias {{ acme_challenge_root }}/;
        try_files $uri =404;
        default_type "text/plain";
        autoindex off;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl;
    listen [::]:443 ssl;
    http2 on;
    server_name {{ domain }}{% for a in aliases %} {{ a }}{% endfor %};

    ssl_certificate     {{ cert_path }};
    ssl_certificate_key {{ key_path }};
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384;
    ssl_prefer_server_ciphers on;
    ssl_session_cache shared:SSL:10m;

    add_header Strict-Transport-Security "max-age=63072000; includeSubDomains" always;
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    server_tokens off;

    access_log {{ logs_dir }}/access.log;
    error_log  {{ logs_dir }}/error.log;

    # Increase body size — reverse proxies often pass file uploads.
    client_max_body_size 256m;

    location / {
        proxy_pass {{ upstream_url }};
        proxy_http_version 1.1;

        # Standard headers so the upstream sees the real client.
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host  $host;
        proxy_set_header X-Forwarded-Port  $server_port;

        # WebSocket upgrade — default on per the MVP spec.
        proxy_set_header Upgrade           $http_upgrade;
        proxy_set_header Connection        "upgrade";

        # Long-poll / SSE / WS friendly.
        proxy_read_timeout  3600s;
        proxy_send_timeout  3600s;
        proxy_buffering off;
    }
}
