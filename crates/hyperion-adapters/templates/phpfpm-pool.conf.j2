[{{ system_user }}]
user = {{ system_user }}
group = {{ system_user }}
listen = /run/php/{{ php_version }}/{{ system_user }}.sock
listen.owner = {{ listen_owner }}
listen.group = {{ listen_group }}
listen.mode = 0660

pm = dynamic
pm.max_children = {{ max_children }}
pm.start_servers = 2
pm.min_spare_servers = 1
pm.max_spare_servers = 3
pm.max_requests = {{ max_requests }}

php_admin_value[memory_limit] = {{ memory_mb }}M
php_admin_value[max_execution_time] = {{ max_exec_secs }}
php_admin_value[upload_max_filesize] = 64M
php_admin_value[post_max_size] = 64M
php_admin_value[open_basedir] = /home/{{ system_user }}/{{ domain }}:/tmp
; Debian's default session.save_path (/var/lib/php/sessions) sits
; OUTSIDE open_basedir, so any hosted app calling session_start()
; (Joomla, PrestaShop, most non-WP PHP, many WP plugins) fails with
; "open_basedir restriction in effect". Point sessions at the
; per-hosting tmp dir (created by ensure_dirs, owned by the user,
; inside open_basedir) — private per site, so no cross-tenant
; session-file reads.
php_admin_value[session.save_path] = /home/{{ system_user }}/{{ domain }}/tmp

; Capture outbound mail for the per-hosting Emails log. The
; wrapper script writes a JSONL line per send to
; /var/lib/hyperion/site-mail/{user}.jsonl and then execs the
; real sendmail so delivery is unaffected. -u flag tells the
; wrapper which hosting it's running for; the wrapper rejects
; values it doesn't recognise so a malicious site can't smuggle
; arguments into the real sendmail.
; (Must use `;` not `#` — Zend INI parser only recognises `;`
; as a comment character; `#` lines are parsed as bare keys and
; trigger "value is NULL for a ZEND_INI_PARSER_ENTRY".)
php_admin_value[sendmail_path] = /usr/local/lib/hyperion/site-mail-wrapper -u {{ system_user }}

catch_workers_output = yes
chdir = /
clear_env = no
